<?xml version="1.0" encoding="UTF-8"?>
<syntax name="pug">
  <meta>
    <name>Pug</name>
    <type>markup</type>
    <preferred-file-extension>pug</preferred-file-extension>
  </meta>

  <detectors>
    <extension priority="1.0">pug</extension>
  </detectors>

  <comments>
    <single>
      <expression>//</expression>
    </single>
  </comments>

  <injection>
    <expression>^(pug|Pug)$</expression>
  </injection>

  <tree-sitter>
    <highlights path="pug/highlights.scm" />
  </tree-sitter>
</syntax>
